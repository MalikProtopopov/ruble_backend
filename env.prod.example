# === App ===
DEBUG=false
SECRET_KEY=CHANGE_ME_STRONG_SECRET
ENCRYPTION_KEY=CHANGE_ME_32_BYTES

# === Domains ===
API_DOMAIN=api.porubly.ru
PUBLIC_API_URL=https://api.porubly.ru
FRONTEND_URL=https://porubly.ru
CORS_ALLOWED_ORIGINS=["https://porubly.ru","https://admin.porubly.ru"]
CERT_EMAIL=admin@porubly.ru

# === Database ===
DATABASE_URL=postgresql+asyncpg://porubly:CHANGE_ME@postgres:5432/porubly
POSTGRES_USER=porubly
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=porubly

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === JWT (RS256) ===
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_AUDIENCE=porubly-api
JWT_ISSUER=porubly

# === S3 / MinIO ===
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=porubly
S3_PUBLIC_URL=https://api.porubly.ru/media

# === YooKassa ===
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# === Notifications ===
NOTIFICATION_PROVIDER=mock

# === Email ===
EMAIL_PROVIDER=mock
