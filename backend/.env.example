# App
DEBUG=true
SECRET_KEY=changeme-dev-only

# Database
DATABASE_URL=postgresql+asyncpg://porubly:porubly@postgres:5432/porubly

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_AUDIENCE=porubly-api
JWT_ISSUER=porubly

# CORS
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# S3 / MinIO
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=porubly
# Dev: http://localhost:8000/media  (FastAPI proxies to MinIO)
# Prod: https://YOUR_API_DOMAIN/media  (nginx proxies to MinIO)
S3_PUBLIC_URL=http://localhost:8000/media

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Notifications
NOTIFICATION_PROVIDER=mock

# Email
EMAIL_PROVIDER=mock
